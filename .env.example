# ============================================================
# .env.example · 环境变量模板 / env variable template
# ============================================================
# 用法 / usage：
#   cp .env.example .env
#   编辑 .env 填入真值；.env 已被 .gitignore 屏蔽 / blocked by gitignore
#   在 shell 中加载：source scripts/load_env.sh
# ============================================================
# 安全 / security：
#   .env 不入 git；不贴对话；不截图；离职 / 设备更换需轮换 key
# ============================================================

# ============================================================
# LLM / 大语言模型 API keys
# ============================================================
# QWEN 通义千问 / Tongyi Qianwen（阿里云百炼）
# 用途 / usage: embedding（向量化）/ rerank（重排）/ llm_assist（LLM 辅助）/ 内容生成
# 控制台 / console: https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=

# DEEPSEEK / 深度求索
# 用途 / usage: llm_assist 备选 / fallback
# 控制台 / console: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ============================================================
# ECS（阿里云服务器）/ Alibaba Cloud ECS
# ============================================================
# SSH 私钥路径 / SSH private key path
ECS_SSH_KEY_PATH=

# ============================================================
# PostgreSQL（关系数据库）/ relational DB on ECS
# ============================================================
PG_HOST=
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=

# ============================================================
# Qdrant（向量数据库）/ vector DB on ECS
# ============================================================
QDRANT_URL_STAGING=
QDRANT_API_KEY=
# prod URL 不放本地 .env；走 CI/CD secrets 注入

# ============================================================
# 模型策略版本 / model policy version
# ============================================================
# 与 knowledge_serving/policies/model_policy.yaml 中的 model_policy_version 字段一致
MODEL_POLICY_VERSION=mp_20260512_001
